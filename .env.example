# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3333
NODE_ENV=production

# ─── Banco de dados (SQLite) ──────────────────────────────────────────────────
# Deixe RTPG_DATA_DIR definido; DATABASE_URL será resolvido automaticamente.
RTPG_DATA_DIR=/opt/rtpg-data
DATABASE_URL=file:/opt/rtpg-data/storage/rtpg.sqlite

# ─── Segurança ────────────────────────────────────────────────────────────────
# MUDE PARA UMA STRING ALEATÓRIA LONGA ANTES DE IR PARA PRODUÇÃO!
# Gere com: openssl rand -hex 32
JWT_SECRET=mude-isso-para-uma-string-segura-em-producao
