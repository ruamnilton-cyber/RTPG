# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3333
NODE_ENV=production

# ─── Banco de dados (SQLite) ──────────────────────────────────────────────────
# Deixe RTPG_DATA_DIR definido; DATABASE_URL será resolvido automaticamente.
RTPG_DATA_DIR=/opt/rtpg-data
DATABASE_URL=file:/opt/rtpg-data/storage/rtpg.sqlite

# ─── Segurança ────────────────────────────────────────────────────────────────
# MUDE PARA UMA STRING ALEATÓRIA LONGA ANTES DE IR PARA PRODUÇÃO!
# Gere com: openssl rand -hex 32
JWT_SECRET=mude-isso-para-uma-string-segura-em-producao

# Amazon SES SMTP
# Gere SES_SMTP_USER e SES_SMTP_PASS no painel do Amazon SES.
SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SES_SMTP_PORT=587
SES_SMTP_USER=
SES_SMTP_PASS=
SES_FROM_EMAIL=comercial@rtpgapp.com
SES_FROM_NAME=RTPG App

# Asaas da plataforma RTPG (para cobrar mensalidade dos restaurantes)
# Use a API Key da SUA conta Asaas. Sandbox=true para testes, false para producao.
PLATFORM_ASAAS_API_KEY=
PLATFORM_ASAAS_SANDBOX=true
# Token configurado no webhook do Asaas. Deve ter 32+ caracteres.
PLATFORM_ASAAS_WEBHOOK_TOKEN=
